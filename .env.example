APP_NAME=Excel Data Assistant
DATA_DIR=data
STORAGE_DIR=storage
RAW_DIR=storage/raw
PARQUET_DIR=storage/parquet
DUCKDB_PATH=storage/duckdb/excel_assistant.duckdb
METADATA_PATH=storage/metadata.json
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=table-summaries
ELASTICSEARCH_VERIFY_CERTS=false
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
EMBEDDING_DIMENSIONS=384
ROW_CHUNK_SIZE=20
MAX_PREVIEW_ROWS=50

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=excel_user
MYSQL_PASSWORD=excel_password
MYSQL_DATABASE=excel_assistant

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=excel-files
MINIO_SECURE=false
TABLE_ARTIFACT_PREFIX=table-artifacts
TABLE_PIPELINE_WORKERS=1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

ENABLE_LLM_ANSWER=false
ENABLE_LLM_TABLE_PARSE=false
ENABLE_SYMBOLIC_CODE_QA=false
ASTRA_PARSE_MODE=enhanced
ASTRA_ARTIFACT_PREFIX=astra-artifacts
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=300

EMBEDDING_PROVIDER=hash
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Base image overrides. Defaults in docker-compose.yml use AWS Public ECR.
PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.12-slim
NODE_BASE_IMAGE=public.ecr.aws/docker/library/node:22-alpine
# MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.4
# MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2025-04-22T22-12-26Z
